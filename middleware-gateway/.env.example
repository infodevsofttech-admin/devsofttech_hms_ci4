# ABDM Bridge Gateway Environment Configuration
# Copy to .env and fill in actual values

# Environment
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Gateway Configuration
BRIDGE_SOURCE_CODE=SBXID_033661
BRIDGE_SYNC_TOKEN=your-bearer-token-here

# ABDM M3 API Configuration
ABDM_M3_URL=https://dev.abdm.gov.in/api/v3
ABDM_M3_TOKEN=your-abdm-m3-bearer-token
BRIDGE_SYNC_TIMEOUT=30

# SNOMED CT Terminology Service
SNOMED_SERVICE_URL=https://csnotk.e-atria.in/csnoserv
SNOMED_TIMEOUT=10

# Optional: For future direct ABDM mode
ABDM_DIRECT_CLIENT_ID=SBXID_033661
ABDM_DIRECT_CLIENT_SECRET=your-client-secret

# Facility Details
ABDM_HFR_ID=your-hfr-id
ABDM_NPI_ID=your-npi-id

# SSL/TLS Configuration (for reverse proxy)
SSL_CERT_PATH=/etc/letsencrypt/live/abdm-bridge.e-atria.in/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/abdm-bridge.e-atria.in/privkey.pem

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_FILE_PATH=/var/log/abdm-gateway/combined.log
ERROR_LOG_PATH=/var/log/abdm-gateway/error.log
